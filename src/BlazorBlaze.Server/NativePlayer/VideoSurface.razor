@using Microsoft.Extensions.Logging
@using Microsoft.JSInterop
@using ModelingEvolution.EventAggregator
@implements IAsyncDisposable
@inject IKioskDetector KioskDetector
@inject IEventAggregator EventAggregator
@inject IJSRuntime JsRuntime
@inject ILogger<VideoSurface> Logger

@if (KioskDetector.IsKiosk)
{
    <div @ref="_placeholderRef"
         style="visibility:hidden; opacity:0; width:@(Width)px; height:@(Height)px; @Style">
    </div>
}
else
{
    <img src="@StreamUrl" style="@Style" class="@Class" alt="@Alt" />
}

@code {
    private static int _nextId;

    private ElementReference _placeholderRef;
    private IJSObjectReference? _jsModule;
    private IJSObjectReference? _jsAdapter;
    private DotNetObjectReference<VideoSurface>? _selfRef;
    private string _resolvedPlayerId = string.Empty;

    [Parameter, EditorRequired]
    public string StreamUrl { get; set; } = default!;

    [Parameter]
    public string? PlayerId { get; set; }

    [Parameter]
    public int Width { get; set; } = 1920;

    [Parameter]
    public int Height { get; set; } = 1080;

    [Parameter]
    public string? Style { get; set; }

    [Parameter]
    public string? Class { get; set; }

    [Parameter]
    public string Alt { get; set; } = "Video stream";

    /// <summary>
    /// Native player background color override. Published as a BackgroundColorChanged
    /// EA event on init. Not restored on dispose (background is global, owned by host).
    /// </summary>
    [Parameter]
    public string? BackgroundColor { get; set; }

    protected override void OnInitialized()
    {
        _resolvedPlayerId = PlayerId ?? $"vs-{Interlocked.Increment(ref _nextId)}";
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || !KioskDetector.IsKiosk)
            return;

        _selfRef = DotNetObjectReference.Create(this);

        _jsModule = await JsRuntime.InvokeAsync<IJSObjectReference>(
            "import", VideoSurfaceConstants.ModulePath);

        _jsAdapter = await _jsModule.InvokeAsync<IJSObjectReference>(
            "createAdapter", _placeholderRef, _resolvedPlayerId, _selfRef);

        var rect = await _jsAdapter.InvokeAsync<PlayerRect>("getRect");

        if (BackgroundColor is not null)
        {
            await EventAggregator.GetEvent<BackgroundColorChanged>()
                .Publish(new BackgroundColorChanged(BackgroundColor));
        }

        await EventAggregator.GetEvent<PlayerInitialized>().Publish(
            new PlayerInitialized(_resolvedPlayerId, StreamUrl, rect.X, rect.Y, rect.Width, rect.Height));

        await EventAggregator.GetEvent<PlayRequested>()
            .Publish(new PlayRequested(_resolvedPlayerId));
    }

    [JSInvokable]
    public Task OnRectChanged(int x, int y, int width, int height)
    {
        return EventAggregator.GetEvent<LayoutChanged>()
            .Publish(new LayoutChanged(_resolvedPlayerId, x, y, width, height));
    }

    public async ValueTask DisposeAsync()
    {
        if (!KioskDetector.IsKiosk || _jsAdapter is null)
        {
            _selfRef?.Dispose();
            _selfRef = null;
            return;
        }

        await EventAggregator.GetEvent<PlayerDestroyed>().Publish(new PlayerDestroyed(_resolvedPlayerId));

        try
        {
            await _jsAdapter.InvokeVoidAsync("dispose");
        }
        catch (JSDisconnectedException ex)
        {
            Logger.LogDebug(ex, "VideoSurface {PlayerId}: circuit disconnected during dispose", _resolvedPlayerId);
        }
        catch (InvalidOperationException ex)
        {
            Logger.LogDebug(ex, "VideoSurface {PlayerId}: JS runtime unavailable during dispose", _resolvedPlayerId);
        }

        try
        {
            if (_jsAdapter is not null)
                await _jsAdapter.DisposeAsync();
            if (_jsModule is not null)
                await _jsModule.DisposeAsync();
        }
        catch (JSDisconnectedException ex)
        {
            Logger.LogDebug(ex, "VideoSurface {PlayerId}: circuit disconnected during JS cleanup", _resolvedPlayerId);
        }
        catch (InvalidOperationException ex)
        {
            Logger.LogDebug(ex, "VideoSurface {PlayerId}: JS runtime unavailable during JS cleanup", _resolvedPlayerId);
        }

        _selfRef?.Dispose();
        _selfRef = null;
    }
}
