@using Microsoft.AspNetCore.Components
@namespace BlazorBlaze.Scene3D

<div @ref="_hostElement" class="scene3d-container" style="width: 100%; height: 100%; position: relative;">
    @if (Renderer is null)
    {
        <div class="scene3d-no-renderer" style="display: flex; align-items: center; justify-content: center; width: 100%; height: 100%; color: #888;">
            No renderer configured. Register an ISceneRenderer implementation.
        </div>
    }
</div>

@code {
    private ElementReference _hostElement;
    private bool _initialized;

    [Parameter]
    public SceneGraph? Scene { get; set; }

    [Parameter]
    public Camera3D? Camera { get; set; }

    [Parameter]
    public ISceneRenderer? Renderer { get; set; }

    [Parameter]
    public EventCallback<NodeClickedEventArgs> OnNodeClicked { get; set; }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && Renderer is not null)
        {
            await Renderer.InitializeAsync(_hostElement);
            Renderer.OnNodeClicked = HandleNodeClickedAsync;
            _initialized = true;
            await RefreshAsync();
        }
    }

    public async Task RefreshAsync()
    {
        if (!_initialized || Renderer is null || Scene is null || Camera is null) return;
        await Renderer.RenderAsync(Scene, Camera);
    }

    private Task HandleNodeClickedAsync(NodeClickedEventArgs args)
    {
        if (OnNodeClicked.HasDelegate)
            return InvokeAsync(() => OnNodeClicked.InvokeAsync(args));
        return Task.CompletedTask;
    }

    public async ValueTask DisposeAsync()
    {
        if (Renderer is not null)
        {
            Renderer.OnNodeClicked = null;
            if (_initialized)
            {
                await Renderer.DisposeAsync();
            }
        }
    }
}
