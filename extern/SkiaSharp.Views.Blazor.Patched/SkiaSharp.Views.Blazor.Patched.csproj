<Project Sdk="Microsoft.NET.Sdk.Razor">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <PackageId>ModelingEvolution.SkiaSharp.Views.Blazor</PackageId>
    <RootNamespace>SkiaSharp.Views.Blazor</RootNamespace>
    <AssemblyName>SkiaSharp.Views.Blazor</AssemblyName>
    <Title>ModelingEvolution SkiaSharp Views for Blazor</Title>
    <Description>Patched SkiaSharp.Views.Blazor with async JS interop for .NET 10 WasmEnableThreads support. Drop-in replacement for SkiaSharp.Views.Blazor — same namespace, same types.</Description>
    <PackageTags>Blazor;SkiaSharp;Canvas;WebAssembly;WASM;Threading</PackageTags>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <DefineConstants>$(DefineConstants);__BLAZOR__</DefineConstants>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <!-- Must match the path hardcoded in SKHtmlCanvasInterop.cs, DpiWatcherInterop.cs, SizeWatcherInterop.cs -->
    <StaticWebAssetBasePath>_content/ModelingEvolution.SkiaSharp.Views.Blazor</StaticWebAssetBasePath>
  </PropertyGroup>

  <ItemGroup>
    <SupportedPlatform Include="browser" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.AspNetCore.Components.Web" />
    <PackageReference Include="SkiaSharp" />
    <PackageReference Include="SkiaSharp.NativeAssets.WebAssembly" />
  </ItemGroup>

  <!-- Source files from SkiaSharp submodule -->
  <PropertyGroup>
    <SkiaViewsBlazorRoot>..\SkiaSharp\source\SkiaSharp.Views\SkiaSharp.Views.Blazor\</SkiaViewsBlazorRoot>
    <SkiaViewsSharedRoot>..\SkiaSharp\source\SkiaSharp.Views\SkiaSharp.Views.Shared\</SkiaViewsSharedRoot>
  </PropertyGroup>

  <ItemGroup>
    <!-- All Internal/*.cs and view code-behind are local overrides for async JS interop (MT WASM fix).
         The submodule versions use [JSImport] with sync function proxies on NET7+, which breaks
         WasmEnableThreads. Local files use DotNetObjectReference + async InvokeAsync instead.
         Local files are auto-included by the SDK from Internal/, SKCanvasView.razor.cs, SKGLView.razor.cs. -->

    <!-- Only these shared types come from the submodule (no MT-related changes needed) -->
    <Compile Include="$(SkiaViewsSharedRoot)SKPaintSurfaceEventArgs.cs" Link="SKPaintSurfaceEventArgs.cs" />
    <Compile Include="$(SkiaViewsSharedRoot)SKPaintGLSurfaceEventArgs.cs" Link="SKPaintGLSurfaceEventArgs.cs" />
  </ItemGroup>

  <ItemGroup>
    <Content Include="$(SkiaViewsBlazorRoot)SKCanvasView.razor" Link="SKCanvasView.razor" />
    <Content Include="$(SkiaViewsBlazorRoot)SKGLView.razor" Link="SKGLView.razor" />
    <Content Include="$(SkiaViewsBlazorRoot)_Imports.razor" Link="_Imports.razor" />
  </ItemGroup>

  <!-- README for NuGet package -->
  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="\" />
  </ItemGroup>

  <!-- Emscripten linker support: provides InterceptBrowserObjects symbol for AOT/Release builds -->
  <ItemGroup>
    <None Include="buildTransitive\ModelingEvolution.SkiaSharp.Views.Blazor.props" Pack="true" PackagePath="buildTransitive\" />
    <None Include="buildTransitive\ModelingEvolution.SkiaSharp.Views.Blazor.targets" Pack="true" PackagePath="buildTransitive\" />
    <None Include="buildTransitive\SkiaSharpInterop.js" Pack="true" PackagePath="buildTransitive\" />
  </ItemGroup>

</Project>
