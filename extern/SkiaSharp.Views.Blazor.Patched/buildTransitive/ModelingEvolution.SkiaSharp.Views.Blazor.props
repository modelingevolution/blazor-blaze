<?xml version="1.0" encoding="utf-8" ?>
<Project>

  <!-- Provides InterceptBrowserObjects symbol required by SkiaSharp native WASM binary at Emscripten link time -->
  <!-- Uses EmccExtraJSLibrary (.NET 10+) with EmccExtraLDFlags fallback for older SDKs -->
  <ItemGroup>
    <EmccExtraJSLibrary Include="$(MSBuildThisFileDirectory)SkiaSharpInterop.js" />
  </ItemGroup>
  <PropertyGroup>
    <EmccExtraLDFlags>$(EmccExtraLDFlags) --js-library="$(MSBuildThisFileDirectory)SkiaSharpInterop.js"</EmccExtraLDFlags>
  </PropertyGroup>

</Project>
